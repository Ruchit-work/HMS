{
  "buildCommand": "git lfs pull && npm run build",
  "crons": [
    {
      "path": "/api/auto-campaigns/generate?check=today&publish=true&sendWhatsApp=true",
      "schedule": "30 00 * * *"
    },
    {
      "path": "/api/appointments/send-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/appointments/auto-mark-missed",
      "schedule": "30 18 * * *"
    }
  ]
}
